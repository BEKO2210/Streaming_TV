<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingStart="58dp"
        android:paddingTop="48dp"
        android:paddingEnd="58dp"
        android:paddingBottom="48dp">

        <androidx.cardview.widget.CardView
            android:layout_width="320dp"
            android:layout_height="200dp"
            android:layout_gravity="center_vertical"
            app:cardBackgroundColor="@color/brand_surface"
            app:cardCornerRadius="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <ImageView
                android:id="@+id/details_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/app_name"
                android:padding="24dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_tv_placeholder" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="40dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/details_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="@color/brand_text"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/details_now"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/brand_accent"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/details_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/brand_text_dim"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/details_description"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="5"
                android:textColor="@color/brand_text_dim"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_play"
                    style="@style/DetailsButton"
                    android:text="@string/action_play" />

                <Button
                    android:id="@+id/button_favorite"
                    style="@style/DetailsButton"
                    android:layout_marginStart="16dp"
                    android:text="@string/action_add_favorite" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
