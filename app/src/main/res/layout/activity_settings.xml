<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="64dp"
        android:paddingTop="40dp"
        android:paddingEnd="64dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/brand_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_source_label"
            android:textColor="@color/brand_text_dim"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/group_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radio_stalker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/source_stalker"
                android:textColor="@color/brand_text" />

            <RadioButton
                android:id="@+id/radio_m3u"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:text="@string/source_m3u"
                android:textColor="@color/brand_text" />
        </RadioGroup>

        <!-- Stalker / MAG portal fields -->
        <LinearLayout
            android:id="@+id/group_stalker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_portal_url"
                android:textColor="@color/brand_text_dim" />

            <EditText
                android:id="@+id/input_portal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="url"
                android:hint="@string/hint_portal_url"
                android:inputType="textUri"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_text_dim" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_mac"
                android:textColor="@color/brand_text_dim" />

            <EditText
                android:id="@+id/input_mac"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="username"
                android:hint="@string/hint_mac"
                android:inputType="textCapCharacters"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_text_dim" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_generate_mac"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_generate_mac" />

                <Button
                    android:id="@+id/button_copy_mac"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/action_copy_mac" />
            </LinearLayout>

            <!-- Card highlighting the MAC to give to the provider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_mac_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mac_for_provider"
                    android:textColor="@color/brand_text_dim"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/text_mac_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="@string/mac_placeholder"
                    android:textColor="@color/brand_accent"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/mac_hint"
                    android:textColor="@color/brand_text_dim"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- M3U fields -->
        <LinearLayout
            android:id="@+id/group_m3u"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_m3u_url"
                android:textColor="@color/brand_text_dim" />

            <EditText
                android:id="@+id/input_m3u"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="url"
                android:hint="@string/hint_m3u_url"
                android:inputType="textUri"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_text_dim" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_save" />

            <Button
                android:id="@+id/button_test"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/action_test" />

            <ProgressBar
                android:id="@+id/test_progress"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="16dp"
                android:indeterminateTint="@color/brand_accent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/test_result"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:textColor="@color/brand_text"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
