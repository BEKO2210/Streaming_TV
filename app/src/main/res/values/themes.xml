<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StreamingTV" parent="Theme.Leanback">
        <item name="android:colorPrimary">@color/brand_accent</item>
        <item name="android:colorAccent">@color/brand_accent</item>
        <item name="android:windowBackground">@color/brand_background</item>
    </style>

    <style name="DetailsButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minWidth">180dp</item>
        <item name="android:textColor">@color/brand_text</item>
        <item name="android:background">@drawable/bg_menu_card</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">18sp</item>
    </style>
</resources>
